# Xcode
build/
DerivedData/
*.xcodeproj
*.xcworkspace
!default.xcworkspace
xcuserdata/
*.xcuserstate
*.xcscmblueprint
*.moved-aside

# Instruments traces captured by tools/trace-device.sh
trace-output/
*.trace

# Swift Package Manager
.build/
.build-dd/
.swiftpm/
Package.resolved

# macOS
.DS_Store

# Local tooling cache (machine-specific; leaks local paths/session ids)
.impeccable/

# Generated
*.generated.swift

# Secrets / local config (never commit)
*.local.xcconfig
Secrets.plist

# Private machine-local agent instructions (never commit; canonical copy lives
# at ~/.copilot/plozz-AGENTS.local.md and is restored into new worktrees by the
# global Copilot instructions).
AGENTS.local.md

# App Store Connect / fastlane secrets (never commit)
.env.fastlane
*.p8
AuthKey_*.p8

# fastlane generated output
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/
fastlane/README.md
# TestFlight "What to Test" notes — local scratch the `beta` lane reads; recomposed per release
WHAT_TO_TEST.txt
Frameworks/
