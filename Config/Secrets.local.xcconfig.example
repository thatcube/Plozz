// Copy this file to `Config/Secrets.local.xcconfig` (gitignored) and set your
// free OMDb API key to enable external IMDb / Rotten Tomatoes / Metacritic
// ratings. Get a key at https://www.omdbapi.com/apikey.aspx. Never commit it.

OMDB_API_KEY = your_free_omdb_key

// TMDb v4 "API Read Access Token" — enables the canonical-poster fallback for
// items with missing/junk provider artwork. Get one at
// https://www.themoviedb.org/settings/api . Never commit it.
TMDB_BEARER_TOKEN = your_tmdb_v4_read_access_token

// Trakt OAuth app credentials — enable syncing your watches to Trakt.
// Create an app at https://trakt.tv/oauth/applications . Never commit these.
TRAKT_CLIENT_ID = your_trakt_client_id
TRAKT_CLIENT_SECRET = your_trakt_client_secret

// Simkl watch tracking (on-device PIN flow — no relay). Only the client
// ID is required. Register at https://simkl.com/apps/ . Never commit.
SIMKL_CLIENT_ID = your_simkl_client_id

// MyAnimeList anime tracking. Auth runs through the plozz.app relay (Cloudflare
// Pages Functions in the `thatcube/plozz-website` repo) — the app needs only the
// client ID; the client SECRET lives on the relay, not here. Register a Web app
// at https://myanimelist.net/apiconfig with redirect URI
// https://plozz.app/auth/mal/callback . Never commit.
MAL_CLIENT_ID = your_mal_client_id

// AniList anime tracking. Also relay-based (implicit grant — no secret needed).
// Register at https://anilist.co/settings/developer with redirect URL
// https://plozz.app/auth/anilist/callback . Never commit.
ANILIST_CLIENT_ID = your_anilist_client_id
