// Copy this file to `Config/Secrets.local.xcconfig` (gitignored) and set your
// free OMDb API key to enable external IMDb / Rotten Tomatoes / Metacritic
// ratings. Get a key at https://www.omdbapi.com/apikey.aspx. Never commit it.

OMDB_API_KEY = your_free_omdb_key

// TMDb v4 "API Read Access Token" — enables the canonical-poster fallback for
// items with missing/junk provider artwork. Get one at
// https://www.themoviedb.org/settings/api . Never commit it.
TMDB_BEARER_TOKEN = your_tmdb_v4_read_access_token

// Trakt OAuth app credentials — enable syncing your watches to Trakt.
// Create an app at https://trakt.tv/oauth/applications . Never commit these.
TRAKT_CLIENT_ID = your_trakt_client_id
TRAKT_CLIENT_SECRET = your_trakt_client_secret
