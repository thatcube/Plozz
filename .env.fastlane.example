# Copy this file to .env.fastlane and fill in your real values, OR export these
# in your shell / CI secrets. Never commit the real key or .env.fastlane.
#
# Create the key at:
#   App Store Connect > Users and Access > Integrations > App Store Connect API
# Download the AuthKey_XXXXXX.p8 once (Apple won't let you re-download it).

# The "Key ID" shown next to the key (e.g. ABC123DEF4)
ASC_KEY_ID=

# The "Issuer ID" at the top of the Integrations page (a UUID)
ASC_ISSUER_ID=

# Absolute path to the downloaded .p8 file, kept outside the repo
ASC_KEY_PATH=/Users/you/.appstoreconnect/keys/AuthKey_ABC123DEF4.p8

# --- Crash reporting (optional) ---------------------------------------------
# Sentry DSN for crash/hang reporting. When set, generate-project.sh bakes it
# into Info.plist (PlozzSentryDSN) so the build has a reporting endpoint; leave
# it empty and crash reporting stays dormant ("unavailable in this build"). A
# DSN is safe to embed in the client (it's write-only ingest), but keep it in
# this gitignored file — never commit it. Find it in Sentry at:
#   Project > Settings > Client Keys (DSN)
# Format: https://<key>@o<org>.ingest.<region>.sentry.io/<project>
PLOZZ_SENTRY_DSN=
