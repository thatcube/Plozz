# Xcode
build/
DerivedData/
*.xcodeproj
*.xcworkspace
!default.xcworkspace
xcuserdata/
*.xcuserstate
*.xcscmblueprint
*.moved-aside

# Instruments traces captured by tools/trace-device.sh
trace-output/
*.trace

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# macOS
.DS_Store

# Generated
*.generated.swift

# Locally-built mpv/FFmpeg xcframeworks (large binaries — never commit). These are
# regenerated by tools/build-mpv-tvos.sh + tools/stage-mpv-frameworks.sh and are
# referenced by EngineMPV's local-path .binaryTargets. See LGPL_COMPLIANCE.md.
Frameworks/mpv/
dist/mpv-tvos/

# Secrets / local config (never commit)
*.local.xcconfig
Secrets.plist

# Private machine-local agent instructions (never commit; canonical copy lives
# at ~/.copilot/plozz-AGENTS.local.md and is restored into new worktrees by the
# global Copilot instructions).
AGENTS.local.md

# App Store Connect / fastlane secrets (never commit)
.env.fastlane
*.p8
AuthKey_*.p8

# fastlane generated output
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/
fastlane/README.md
Frameworks/
