# Fastfile — App Store Connect automation for Plozz (tvOS)
#
# Authentication uses an App Store Connect API key (no Apple ID / 2FA needed),
# which is required for unattended runs and CI. Provide these via env vars
# (see .env.fastlane.example) or your CI secrets:
#
#   ASC_KEY_ID       Key ID from App Store Connect > Integrations > App Store Connect API
#   ASC_ISSUER_ID    Issuer ID from the same page
#   ASC_KEY_PATH     Path to the downloaded AuthKey_XXXXXX.p8  (keep it OUT of git)
#
# Usage (Fastlane installed via Homebrew):
#   fastlane beta       # build + upload to TestFlight
#   fastlane build      # archive an .ipa locally, no upload
#   fastlane release    # build + upload to App Store
#
# ONE-TIME SETUP (manual): the App Store Connect API key cannot create the app
# record itself (Apple exposes no "create app" API and `produce` needs an Apple
# ID + 2FA). Before the first `beta`, create the app once in the App Store
# Connect web UI:  Apps > + > New App  ->  Platform: tvOS, Name: Plozz,
# Bundle ID: com.thatcube.Plozz (team N8Z5T4AK3X), SKU: plozz-tvos.
# The bundle ID registration and distribution signing are handled automatically
# by `build` via -allowProvisioningUpdates + the API key.

require "shellwords"

APP_IDENTIFIER = "com.thatcube.Plozz"
APP_NAME       = "Plozz"
SCHEME         = "Plozz"
XCODEPROJ      = "Plozz.xcodeproj"
OUTPUT_DIR     = "build"
# tvOS apps are a distinct App Store "platform"; deliver/pilot default to iOS
# unless told otherwise, so every upload must specify this explicitly.
APP_PLATFORM   = "appletvos"
# External TestFlight beta group builds are distributed to (created once in the
# App Store Connect web UI). The internal group already has access to all builds
# automatically, so `beta` only has to add + submit for this external one.
EXTERNAL_GROUP = "Plozz External"

# The host GitHub desktop/CLI app injects safe.bareRepository=explicit via
# GIT_CONFIG_* env vars, which breaks Swift Package Manager's bare dependency
# checkouts during xcodebuild. Relax just that one value back to git's default
# for everything fastlane spawns.
if ENV["GIT_CONFIG_KEY_0"] == "safe.bareRepository"
  ENV["GIT_CONFIG_VALUE_0"] = "all"
end

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_KEY_PATH"),
    in_house: false
  )
end

# App Store Connect rejects any build made with a BETA Xcode / SDK (altool error
# 90534 "Unsupported SDK or Xcode version"). This machine keeps the beta as the
# active `xcode-select` toolchain (/Applications/Xcode-beta.app), so an
# unqualified fastlane run would build with the beta SDK and the upload would be
# rejected. Point every fastlane build at a RELEASE Xcode automatically so
# uploads always succeed — no manual `DEVELOPER_DIR` / `xcode-select` dance.
#
# Resolution order:
#   1. An explicit non-beta DEVELOPER_DIR the caller already exported (respected).
#   2. The conventional release install at /Applications/Xcode.app.
#   3. The highest-versioned /Applications/Xcode*.app whose name isn't "beta".
def select_release_xcode
  beta = ->(path) { path.downcase.include?("beta") }

  # Respect an explicit, non-beta override.
  if (dd = ENV["DEVELOPER_DIR"]) && !dd.empty?
    if beta.call(dd)
      UI.important("DEVELOPER_DIR points at a beta Xcode (#{dd}); overriding with a release Xcode.")
    else
      UI.message("Using caller-provided DEVELOPER_DIR: #{dd}")
      return
    end
  end

  candidates = Dir.glob("/Applications/Xcode*.app").reject { |p| beta.call(p) }
  # Prefer the canonical release path, then fall back to the newest remaining.
  chosen = candidates.find { |p| p == "/Applications/Xcode.app" }
  chosen ||= candidates.sort.last

  unless chosen
    UI.user_error!("No release Xcode found in /Applications (only a beta is installed). " \
                   "Install a release Xcode — App Store Connect rejects beta-SDK builds.")
  end

  developer_dir = File.join(chosen, "Contents", "Developer")
  ENV["DEVELOPER_DIR"] = developer_dir
  version = `DEVELOPER_DIR=#{developer_dir.shellescape} xcodebuild -version 2>/dev/null`.strip.gsub("\n", " ")
  UI.success("Building with release Xcode: #{chosen} (#{version})")
end

# Next build number = (latest build already on TestFlight for this app+platform)
# + 1. initial_build_number: 0 makes the very first build a clean 1 when no
# builds exist yet. Falls back to 1 only if App Store Connect can't be reached.
def next_build_number
  latest = latest_testflight_build_number(
    api_key: asc_api_key,
    app_identifier: APP_IDENTIFIER,
    platform: APP_PLATFORM,
    initial_build_number: 0
  )
  latest.to_i + 1
rescue => e
  UI.important("Couldn't fetch latest TestFlight build number (#{e.message}); defaulting to 1")
  1
end

# Release notes shown to testers as TestFlight's "What to Test". Sourced from the
# PLOZZ_WHATS_NEW env var first (so agent/scripted runs can pass it inline), else
# a repo-root WHAT_TO_TEST.txt file (gitignored scratch or committed notes). An
# external beta must have notes, so `beta` errors clearly if both are empty.
def whats_new
  txt = ENV["PLOZZ_WHATS_NEW"]
  if (txt.nil? || txt.strip.empty?)
    path = File.expand_path("../WHAT_TO_TEST.txt", __dir__)
    txt = File.read(path) if File.exist?(path)
  end
  (txt || "").strip
end

# Tags the shipped commit `release/<build>` and opens a GitHub Release with an
# auto changelog (commits since the previous release tag) plus the tester notes.
# Best-effort: a missing/failed `gh` or git push warns but never fails the ship —
# the upload already succeeded by the time this runs.
#
# `build_number` is the CFBundleVersion that was uploaded (sequential TestFlight
# number, set by the `build` lane). `prerelease` marks TestFlight betas as GitHub
# pre-releases; an App Store `release` marks the GitHub release as the latest.
def tag_github_release(build_number, notes, prerelease)
  return UI.important("No build number available; skipping release tag.") if build_number.nil? || build_number.to_s.strip.empty?

  # The host may inject `safe.bareRepository=explicit` (worktree checkouts); the
  # override is harmless in a normal clone, so set it defensively for our git calls.
  ENV["GIT_CONFIG_PARAMETERS"] ||= "'safe.bareRepository=all'"
  ident = "-c user.name='Brandon Moore' -c user.email='16313090+thatcube@users.noreply.github.com'"
  tag = "release/#{build_number}"
  prev_tag = "release/#{build_number.to_i - 1}"

  begin
    sh("cd .. && git #{ident} tag -a -f #{tag} -m 'TestFlight build #{build_number}'")
    sh("cd .. && git push origin -f #{tag}")
  rescue => e
    return UI.important("Release tagging failed (#{e.message}); ship succeeded, tag manually.")
  end

  has_prev = (sh("cd .. && git rev-parse -q --verify refs/tags/#{prev_tag} >/dev/null 2>&1 && echo yes || echo no").strip == "yes")
  changelog =
    if has_prev
      (sh("cd .. && git log --no-merges --pretty='- %s' #{prev_tag}..#{tag}").strip)
    else
      "- Initial tagged release."
    end
  changelog = "- (no changes recorded)" if changelog.empty?

  # Release title = the app's CalVer marketing version (e.g. "2026.7.18"), read from
  # the generated project (generate-project.sh bakes MARKETING_VERSION = build date).
  # Falls back to today's CalVer if it can't be read. The build number still shows in
  # the release via its `release/<N>` tag, so same-day builds remain distinguishable.
  today_cal = "#{Time.now.year}.#{Time.now.month}.#{Time.now.day}"
  version =
    begin
      v = sh("cd .. && grep -m1 'MARKETING_VERSION' Plozz.xcodeproj/project.pbxproj 2>/dev/null | grep -oE '[0-9]+\\.[0-9]+\\.[0-9]+' || true").strip
      v.empty? ? today_cal : v
    rescue
      today_cal
    end
  date = Time.now.strftime("%Y-%m-%d")
  body = +"TestFlight build #{build_number} — #{date}\n"
  body << "\nWhat to Test:\n#{notes.strip}\n" unless notes.strip.empty?
  body << "\nChanges:\n#{changelog}\n"

  require "tempfile"
  file = Tempfile.new(["release-#{build_number}", ".md"])
  file.write(body)
  file.close
  flag = prerelease ? "--prerelease" : "--latest"
  begin
    sh("cd .. && gh release create #{tag} --verify-tag --title #{version.shellescape} --notes-file #{file.path.shellescape} #{flag}")
    UI.success("Created GitHub release #{tag} (#{version})")
  rescue => e
    UI.important("gh release create failed (#{e.message}); the tag is pushed — create the release manually.")
  ensure
    file.unlink
  end
end

desc "Regenerate the Xcode project from project.yml via XcodeGen"
lane :generate_project do
  # generate-project.sh runs xcodegen and bakes the build number (PLOZZ_BUILD_NUMBER
  # override, else git commit count) into CFBundleVersion so it's never missed.
  sh("cd .. && ./tools/generate-project.sh")
end

desc "Archive and export a signed App Store .ipa (no upload)"
lane :build do |options|
  # App Store Connect rejects beta-SDK builds, and this machine's active toolchain
  # is the Xcode beta — force a release Xcode before anything compiles.
  select_release_xcode

  # Build number must strictly increase per upload for a given marketing version.
  # TestFlight is the source of truth, so derive the next build from (latest
  # TestFlight build + 1). Set it BEFORE generating the project so generate-project.sh
  # bakes it into CFBundleVersion for both the app and the Top Shelf extension.
  # Marketing version (CFBundleShortVersionString) stays manual in project.yml —
  # bump it by hand for real releases.
  build_number = next_build_number
  ENV["PLOZZ_BUILD_NUMBER"] = build_number.to_s
  UI.message("Using build number #{build_number} (CFBundleVersion)")

  generate_project

  # Let Xcode create/download the distribution certificate and provisioning
  # profile on first run, authenticating with the same App Store Connect API key.
  prov_args = "-allowProvisioningUpdates"
  if ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"] && ENV["ASC_KEY_PATH"]
    prov_args += " -authenticationKeyPath #{ENV['ASC_KEY_PATH'].shellescape}" \
                 " -authenticationKeyID #{ENV['ASC_KEY_ID'].shellescape}" \
                 " -authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID'].shellescape}"
  end
  build_app(
    project: XCODEPROJ,
    scheme: SCHEME,
    configuration: "Release",
    export_method: "app-store",
    output_directory: OUTPUT_DIR,
    clean: true,
    xcargs: prov_args
  )
end

desc "Build and upload a new build to TestFlight (internal + external)"
lane :beta do
  api_key = asc_api_key
  # An external beta must ship with "What to Test" notes and passes Apple's beta
  # review, so require the notes up front before spending minutes on the build.
  notes = whats_new
  if notes.empty?
    UI.user_error!(
      "No release notes for the external beta. Provide them before running `beta`:\n" \
      "  • export PLOZZ_WHATS_NEW=\"...\"   (inline), or\n" \
      "  • create WHAT_TO_TEST.txt at the repo root."
    )
  end
  build
  upload_to_testflight(
    api_key: api_key,
    app_identifier: APP_IDENTIFIER,
    app_platform: APP_PLATFORM,
    # Always distribute to external testers, not just the internal group. The
    # internal "Testas" group already auto-receives every build.
    distribute_external: true,
    groups: [EXTERNAL_GROUP],
    notify_external_testers: true,
    # Sets TestFlight's "What to Test" natively (no separate ASC API call) and
    # submits the build for Apple's beta review so external testers can get it.
    changelog: notes,
    submit_beta_review: true,
    # Must wait for processing to finish so the build can be submitted for review
    # and distributed — can't skip when distributing externally.
    skip_waiting_for_build_processing: false
  )

  # Tag the shipped commit and open a GitHub pre-release with the changelog + notes.
  tag_github_release(ENV["PLOZZ_BUILD_NUMBER"], notes, true)
end

desc "Build and upload to the App Store (no auto-submit for review)"
lane :release do
  api_key = asc_api_key
  build
  upload_to_app_store(
    api_key: api_key,
    app_identifier: APP_IDENTIFIER,
    platform: APP_PLATFORM,
    submit_for_review: false,
    skip_screenshots: true,
    precheck_include_in_app_purchases: false,
    force: true
  )

  # Tag the shipped commit and open a GitHub release (marked latest) with the
  # changelog and any tester notes.
  tag_github_release(ENV["PLOZZ_BUILD_NUMBER"], whats_new, false)
end
